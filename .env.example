# MongoDB connection string (use a MongoDB Atlas cluster for production)
MONGODB_URI=mongodb://localhost/blogify

# Secret used to sign JWT auth tokens (use a long random string)
JWT_SECRET=change-me-to-a-long-random-string

# Google Generative AI (Gemini) API key
GEMINI_API_KEY=your-gemini-api-key

# Port (Render sets this automatically; only needed for local runs)
PORT=3000
