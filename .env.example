# MongoDB connection string.
# Local dev: a local MongoDB. On Railway: reference the MongoDB service,
# e.g. set MONGODB_URI to ${{MongoDB.MONGO_URL}}/blogify in the dashboard.
MONGODB_URI=mongodb://localhost/blogify

# Secret used to sign JWT auth tokens (use a long random string)
JWT_SECRET=change-me-to-a-long-random-string

# Port (Railway sets this automatically; only needed for local runs)
PORT=3000
