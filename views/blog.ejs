<!DOCTYPE html>
<html lang="en">

<head>
    <title>Blogify — Home</title>
    <%- include('./partials/head') %>
    <style>
        .blog-img-top {
            width: 100%;
            height: 200px;
            object-fit: cover;
        }

        .blog-title {
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .author-avatar {
            width: 32px;
            height: 32px;
            object-fit: cover;
        }
    </style>
</head>

<body>
    <%- include('./partials/navbar') %>

    <!-- Hero -->
    <header class="page-header text-center">
        <div class="container">
            <h1 class="display-5 mb-2">Stories worth reading</h1>
            <p class="lead mb-3 opacity-75">Discover ideas, share your voice, and explore the community blog.</p>
            <% if (locals.user) { %>
                <a href="/blogs/create" class="btn btn-light fw-semibold"><i class="bi bi-pencil me-1"></i>Write a blog</a>
            <% } else { %>
                <a href="/user/signup" class="btn btn-light fw-semibold">Get started</a>
            <% } %>
        </div>
    </header>

    <div class="container pb-5">
        <% if (locals.Blogs && Blogs.length > 0) { %>
            <div class="row g-4">
                <% Blogs.forEach(blog=> { %>
                    <div class="col-lg-4 col-md-6">
                        <div class="card card-hover h-100">
                            <img class="blog-img-top" src="<%= blog.coverImageUrl %>" alt="<%= blog.title %>">
                            <div class="card-body d-flex flex-column">
                                <h5 class="blog-title card-title"><%= blog.title %></h5>
                                <div class="d-flex align-items-center gap-2 text-muted small mt-2 mb-3">
                                    <% if (blog.generatedBy) { %>
                                        <img class="rounded-circle author-avatar border"
                                            src="<%= blog.generatedBy.profilePictureURL || '/images/default.jpg' %>" alt="author">
                                        <span class="text-capitalize"><%= blog.generatedBy.fullName %></span>
                                        <span>·</span>
                                    <% } %>
                                    <span><%= new Date(blog.createdAt).toLocaleDateString() %></span>
                                </div>
                                <a href="/blogs/<%= blog._id %>" class="btn btn-outline-primary mt-auto">Read more <i class="bi bi-arrow-right ms-1"></i></a>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div class="text-center py-5">
                <i class="bi bi-journal-text display-1 text-muted opacity-50"></i>
                <h3 class="mt-3">No blogs yet</h3>
                <p class="text-muted">Be the first to share a story.</p>
                <% if (locals.user) { %>
                    <a href="/blogs/create" class="btn btn-primary">Create the first blog</a>
                <% } else { %>
                    <a href="/user/signup" class="btn btn-primary">Sign up to write</a>
                <% } %>
            </div>
        <% } %>
    </div>

    <%- include('./partials/script') %>
</body>

</html>
