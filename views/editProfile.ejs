<!DOCTYPE html>
<html lang="en">

<head>
    <title>Account — Blogify</title>
    <%- include('./partials/head') %>
</head>

<body>
    <%- include('./partials/navbar') %>
    <div class="container my-4" style="max-width: 720px;">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4 p-md-5 text-center">
                <img src="<%= locals.user.profilePictureURL || '/images/default.jpg' %>"
                    alt="<%= locals.user.fullName %>" class="rounded-circle border shadow-sm"
                    width="120" height="120" style="object-fit: cover;">
                <h2 class="text-capitalize mt-3 mb-0"><%= locals.user.fullName %></h2>
                <p class="text-muted">@<%= locals.user.username %></p>
                <% if (locals.user.role === "ADMIN") { %>
                    <span class="badge bg-primary mb-3">Admin</span>
                <% } %>

                <div class="text-start mt-4">
                    <div class="card mb-3">
                        <div class="card-header bg-white fw-semibold">About</div>
                        <div class="card-body">
                            <p class="card-text mb-0"><%= locals.user.bio || "This user hasn't added a bio yet." %></p>
                        </div>
                    </div>
                    <div class="card">
                        <div class="card-header bg-white fw-semibold">Contact Information</div>
                        <div class="card-body">
                            <p class="card-text mb-2"><i class="bi bi-envelope me-2 text-muted"></i><%= locals.user.email %></p>
                            <p class="card-text mb-0"><i class="bi bi-telephone me-2 text-muted"></i><%= locals.user.phone || "—" %></p>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2 justify-content-center mt-4">
                    <a href="/user/profile/<%= locals.user._id %>" class="btn btn-light">Back to Profile</a>
                    <form action="/user/delete" method="POST" class="d-inline">
                        <button type="submit" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Delete Account</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
    <%- include('./partials/script') %>
</body>

</html>
