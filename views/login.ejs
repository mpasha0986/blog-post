<!DOCTYPE html>
<html lang="en">

<head>
    <title>Login — Blogify</title>
    <%- include('./partials/head') %>
</head>

<body>
    <%- include('./partials/navbar') %>
    <div class="container">
        <div class="auth-card">
            <div class="text-center mb-4">
                <i class="bi bi-box-arrow-in-right display-5 text-primary"></i>
                <h2 class="mt-2">Welcome back</h2>
                <p class="text-muted">Log in to continue to Blogify</p>
            </div>

            <% if (locals.error) { %>
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <%= locals.error %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            <% } %>

            <form action="/user/login" method="post">
                <div class="mb-3">
                    <label for="email" class="form-label">Email Address</label>
                    <input type="email" class="form-control" name="email" id="email" placeholder="you@example.com" required>
                </div>
                <div class="mb-3">
                    <label for="password" class="form-label">Password</label>
                    <input type="password" class="form-control" name="password" id="password" placeholder="••••••••" required>
                </div>
                <button type="submit" class="btn btn-primary w-100">Login</button>
            </form>

            <div class="text-center mt-3">
                <p class="mb-0">Don't have an account? <a href="/user/signup">Sign Up</a></p>
            </div>
        </div>
    </div>
    <%- include('./partials/script') %>
</body>

</html>
