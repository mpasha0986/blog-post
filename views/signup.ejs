<!DOCTYPE html>
<html lang="en">

<head>
    <title>Sign Up — Blogify</title>
    <%- include('./partials/head') %>
</head>

<body>
    <%- include('./partials/navbar') %>
    <div class="container">
        <div class="auth-card" style="max-width: 620px;">
            <div class="text-center mb-4">
                <i class="bi bi-person-plus display-5 text-primary"></i>
                <h2 class="mt-2">Create your account</h2>
                <p class="text-muted">Join Blogify and start sharing</p>
            </div>

            <% if (locals.error) { %>
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <%= locals.error %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            <% } %>

            <form method="post" action="/user/signup" enctype="multipart/form-data">
                <div class="row">
                    <div class="mb-3 col-md-6">
                        <label for="fullName" class="form-label">Full Name</label>
                        <input type="text" class="form-control" name="fullName" id="fullName" required>
                    </div>
                    <div class="mb-3 col-md-6">
                        <label for="username" class="form-label">Username</label>
                        <input type="text" class="form-control" name="username" id="username" required>
                    </div>
                </div>

                <div class="mb-3">
                    <label for="bio" class="form-label">Bio</label>
                    <textarea class="form-control" name="bio" id="bio" rows="2" style="resize: none;"
                        placeholder="Tell us a little about yourself"></textarea>
                </div>

                <div class="mb-3">
                    <label for="email" class="form-label">Email Address</label>
                    <input type="email" class="form-control" name="email" id="email" required>
                </div>

                <div class="row">
                    <div class="mb-3 col-md-6">
                        <label for="password" class="form-label">Password</label>
                        <input type="password" class="form-control" name="password" id="password" required>
                    </div>
                    <div class="mb-3 col-md-6">
                        <label for="confirmPassword" class="form-label">Confirm Password</label>
                        <input type="password" class="form-control" name="confirmPassword" id="confirmPassword" required>
                    </div>
                </div>

                <div class="mb-3">
                    <label for="profilePicture" class="form-label">Profile Picture</label>
                    <input type="file" class="form-control" name="profilePicture" id="profilePicture" accept="image/*">
                </div>

                <button type="submit" class="btn btn-primary w-100">Sign Up</button>
            </form>

            <div class="text-center mt-3">
                <p class="mb-0">Already have an account? <a href="/user/login">Log In</a></p>
            </div>
        </div>
    </div>
    <%- include('./partials/script') %>
</body>

</html>
