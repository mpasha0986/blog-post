<!DOCTYPE html>
<html lang="en">

<head>
    <title><%= locals.blog ? locals.blog.title : "Blog" %></title>
    <%- include('./partials/head') %>
</head>

<body>
    <!-- Navbar -->
    <%- include('./partials/navbar') %>

    <% if (locals.error) { %>
        <div class="container">
            <div class="alert alert-danger text-center mt-4" role="alert">
                <strong>Error:</strong> This blog could not be found.
            </div>
            <div class="text-center">
                <a href="/blogs" class="btn btn-primary"><i class="bi bi-arrow-left me-1"></i>Back to blogs</a>
            </div>
        </div>
    <% } else {
        const isOwner = locals.user && locals.blog.generatedBy
            && String(locals.user._id) === String(locals.blog.generatedBy._id);
    %>
        <div class="container my-4" style="max-width: 820px;">
            <a href="/blogs" class="btn btn-link text-decoration-none px-0 mb-2"><i class="bi bi-arrow-left me-1"></i>Back to blogs</a>

            <!-- Blog Content -->
            <article class="card border-0 shadow-sm">
                <img src="<%= locals.blog.coverImageUrl %>" class="card-img-top" style="max-height: 380px; object-fit: cover;"
                    alt="<%= locals.blog.title %>">
                <div class="card-body p-4 p-md-5">
                    <% if (isOwner) { %>
                        <div class="d-flex justify-content-end gap-2 mb-3">
                            <a href="/blogs/edit/<%= locals.blog._id %>" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil me-1"></i>Edit
                            </a>
                            <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="modal"
                                data-bs-target="#deleteBlogModal">
                                <i class="bi bi-trash me-1"></i>Delete
                            </button>
                        </div>
                    <% } %>

                    <h1 class="display-6 mb-4"><%= locals.blog.title %></h1>

                    <div class="d-flex align-items-center border-top border-bottom py-3 mb-4">
                        <img src="<%= (locals.blog.generatedBy && locals.blog.generatedBy.profilePictureURL) || '/images/default.jpg' %>"
                            class="rounded-circle me-3 border" width="52" height="52" style="object-fit: cover;" alt="Profile Picture">
                        <div>
                            <p class="mb-0 fw-semibold text-capitalize">
                                <%= locals.blog.generatedBy ? locals.blog.generatedBy.fullName : "Unknown author" %>
                            </p>
                            <p class="text-muted small mb-0">
                                <i class="bi bi-calendar3 me-1"></i><%= new Date(locals.blog.createdAt).toLocaleDateString() %>
                            </p>
                        </div>
                    </div>

                    <div class="fs-5 lh-lg" style="white-space: pre-wrap;"><%- locals.blog.body %></div>
                </div>
            </article>

            <!-- Comments Section -->
            <div class="card border-0 shadow-sm mt-4">
                <div class="card-body p-4">
                    <h4 class="mb-4"><i class="bi bi-chat-left-text me-2"></i>Comments (<%= locals.comments.length %>)</h4>

                    <% if (locals.user) { %>
                        <form method="post" action="/blogs/comment/<%= locals.blog._id %>" class="mb-4">
                            <div class="input-group">
                                <input type="text" class="form-control" id="commentInput" name="content"
                                    placeholder="Share your thoughts..." required>
                                <button class="btn btn-primary" type="submit">Post</button>
                            </div>
                        </form>
                    <% } else { %>
                        <p class="text-muted"><a href="/user/login">Log in</a> to join the conversation.</p>
                    <% } %>

                    <% if (locals.comments.length === 0) { %>
                        <p class="text-muted text-center py-3 mb-0">No comments yet. Be the first!</p>
                    <% } %>
                    <% locals.comments.forEach(comment=> { %>
                        <div class="d-flex align-items-start mb-3">
                            <img src="<%= (comment.generatedBy && comment.generatedBy.profilePictureURL) || '/images/default.jpg' %>"
                                class="rounded-circle me-3 border" width="44" height="44" style="object-fit: cover;" alt="Profile Picture">
                            <div class="bg-light rounded-3 px-3 py-2 flex-grow-1">
                                <p class="mb-1 fw-semibold text-capitalize">
                                    <%= comment.generatedBy ? comment.generatedBy.fullName : "Unknown" %>
                                </p>
                                <p class="mb-0 text-muted" style="white-space: pre-wrap;"><%- comment.content %></p>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>
        </div>

        <!-- Delete Blog Modal -->
        <% if (isOwner) { %>
            <div class="modal fade" id="deleteBlogModal" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">Delete Blog</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            Are you sure you want to delete <strong><%= locals.blog.title %></strong>? This cannot be undone.
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <form method="post" action="/blogs/delete/<%= locals.blog._id %>" class="d-inline">
                                <button type="submit" class="btn btn-danger">Delete</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        <% } %>
    <% } %>

    <!-- Scripts -->
    <%- include('./partials/script') %>
</body>

</html>
